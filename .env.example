# ─── Content Studio environment ─────────────────────────────────────────────
# Copy this file to ".env" and fill in your keys. Never commit the real .env.

# REQUIRED NOW — unlocks YouTube outlier data + transcripts
APIFY_TOKEN=

# Your own channel (used by Brand Analyst)
MY_CHANNEL_URL=https://www.youtube.com/@SuhaibAIAutomation
MY_CHANNEL_HANDLE=@SuhaibAIAutomation

# LATER PHASES — leave blank for now, add when ready
OPENROUTER_API_KEY=        # optional: cheap bulk transcript analysis (Claude does it otherwise)
NANO_BANANA_API_KEY=       # thumbnails (Thumbnail Studio phase)
DESCRIPT_API_KEY=          # editing (Editor phase)
YOUTUBE_API_KEY=           # publishing + your own channel stats (Publisher phase)

# ─── Outlier scoring knobs (safe defaults, tune later) ──────────────────────
OUTLIER_MIN_MULTIPLIER=2.5     # flag videos with >= this many x the channel's median views
OUTLIER_LOOKBACK_DAYS=45       # only consider videos published in the last N days
SMALL_CHANNEL_MAX_SUBS=50000   # boost ranking for channels under this sub count
OUTLIER_MIN_VIEWS=3000         # ignore outliers below this absolute view count (kills noise)
